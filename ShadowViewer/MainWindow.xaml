<winUiEx:WindowEx
    x:Class="ShadowViewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winUiEx="using:WinUIEx"
    Title="ShadowViewer"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    <Grid>
        <Grid x:Name="MainGrid" MinWidth="650">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

        </Grid>
        <Grid
            x:Name="LoadingGrid"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
            <StackPanel
                MaxWidth="600"
                MaxHeight="400"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Loaded="InAnimationLoadingGridOnLoaded"
                Orientation="Vertical"
                Spacing="10">
                <animations:Explicit.Animations>
                    <animations:AnimationSet x:Name="InAnimationLoadingGrid">
                        <animations:TranslationAnimation
                            EasingMode="EaseIn"
                            From="0,60"
                            To="0,0"
                            Duration="0:0:0.4" />
                        <animations:OpacityAnimation
                            EasingMode="EaseIn"
                            From="0"
                            To="1"
                            Duration="0:0:0.4" />
                    </animations:AnimationSet>
                </animations:Explicit.Animations>
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <BitmapIcon
                        Width="120"
                        ShowAsMonochrome="False"
                        UriSource="ms-appx:///Assets/StoreLogo.scale-400.png" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe UI Variable Display"
                        FontSize="54"
                        FontWeight="ExtraBlack"
                        Text="ShadowViewer" />
                </StackPanel>
                <ProgressRing
                    Width="56"
                    Height="56"
                    HorizontalAlignment="Center"
                    IsActive="True"
                    IsIndeterminate="True" />
                <TextBlock x:Name="LoadingText" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</winUiEx:WindowEx>